helper/.venv
helper/pip-log.txt
helper/pip-delete-this-directory.txt
helper/.tox/
helper/.coverage
helper/.coverage.*
helper/.cache
helper/nosetests.xml
helper/coverage.xml
helper/*.cover
helper/*.py,cover
helper/.hypothesis/
helper/.pytest_cache/
helper/pytestdebug.log

