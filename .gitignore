helper/*$py.class
helper/.Python
helper/build/
helper/develop-eggs/
helper/dist/
helper/downloads/
helper/eggs/
helper/.eggs/
helper/lib/
helper/lib64/
helper/parts/
helper/sdist/
helper/var/
helper/wheels/
helper/*.egg-info/
helper/.installed.cfg
helper/*.egg
helper/venv/
helper/ENV/
helper/env/
